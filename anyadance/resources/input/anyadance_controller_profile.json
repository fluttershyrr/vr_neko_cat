    "/input/application_menu": {
      "binding_image_point": [320, 60],
      "type": "button",
      "click": true,
      "order": 2
    },
    "/input/a": {
      "binding_image_point": [320, 100],
      "type": "button",
      "click": true,
      "order": 5
    },
    "/input/b": {
      "binding_image_point": [320, 140],
      "type": "button",
      "click": true,
      "order": 6
    },
    "/input/grip": {
      "binding_image_point": [210, 130],
